# Copy these values into your hosting provider's environment variable settings.
# Do not commit real secrets.

# Production mode disables local .env loading and requires auth credentials.
IA_ENV=production
IA_LOAD_LOCAL_ENV=0
IA_CORTEX_FRONTEND_AUTOSTART=0

# Browser login. Use a long random password from a password manager.
IA_AUTH_ENABLED=1
IA_AUTH_PUBLIC_HEALTH=1
IA_AUTH_USERNAME=investor
IA_AUTH_PASSWORD=

# Optional machine-to-machine API token.
IA_AUTH_BEARER_TOKEN=

# If frontend and backend are on different domains, add the frontend origin here.
# Example: https://your-cortex.netlify.app
IA_CORS_ORIGINS=

# Backend bind settings for production hosting.
IA_BACKEND_V2_HOST=0.0.0.0
IA_BACKEND_V2_PORT=8001

# Runtime data path. On a hosted server, point this at persistent disk/volume.
IA_DB_PATH=storage/investment_agent.sqlite3

# Market/data provider keys. Configure only the providers you use.
FINNHUB_API_KEY=
FRED_API_KEY=
POLYGON_API_KEY=
EODHD_API_KEY=
TIINGO_API_KEY=
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FMP_API_KEY=
NASDAQ_DATA_LINK_API_KEY=

# Optional local forecasting sidecars.
IA_CHRONOS_BASE_URL=
IA_TIMESFM_BASE_URL=
IA_MOIRAI_BASE_URL=
IA_LAGLLAMA_BASE_URL=
